{
    "name": "mem-vector",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 2500",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "db:up": "~/scripts/supabase-local up mem-vector",
        "db:down": "~/scripts/supabase-local down mem-vector",
        "db:status": "~/scripts/supabase-local status mem-vector",
        "db:start": "npm run db:up",
        "db:stop": "npm run db:down",
        "seed:user": "tsx scripts/seed-user.ts",
        "seed:fresh": "tsx scripts/seed-fresh.ts",
        "sim-measure": "tsx scripts/sim-measure.ts",
        "evals": "tsx scripts/evals-placement.ts",
        "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:run",
        "prepare": "husky"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@radix-ui/react-alert-dialog": "^1.1.16",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-dialog": "^1.1.16",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.3.0",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.107.0",
        "@xenova/transformers": "^2.17.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "lucide-react": "^0.562.0",
        "next": "^16.2.7",
        "next-themes": "^0.4.6",
        "react": "19.2.3",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.3",
        "react-force-graph-2d": "^1.29.1",
        "react-force-graph-3d": "^1.29.1",
        "react-hook-form": "^7.69.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^5.1.4",
        "autoprefixer": "^10.4.21",
        "eslint": "^9",
        "eslint-config-next": "16.1.1",
        "husky": "^9.1.7",
        "jsdom": "^28.0.0",
        "lint-staged": "^16.2.7",
        "playwright": "^1.58.2",
        "postcss": "^8.5.6",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "tailwindcss": "^3.4.17",
        "tailwindcss-animate": "^1.0.7",
        "tsx": "^4.22.4",
        "typescript": "^5",
        "vitest": "^4.0.18"
    },
    "lint-staged": {
        "src/**/*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "src/**/*.css": [
            "prettier --write"
        ]
    }
}
