# Supabase (Auth + Postgres + pgvector + Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (RLS bypass — usar só no backend, nunca no cliente)
SUPABASE_SERVICE_ROLE_KEY=

# RAG / embeddings (a definir na fase RAG+Chat)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
MEMVECTOR_KEYS_SECRET=<openssl rand -hex 32>

# --- Dependências de host (#123, Ponte G) — ver docs/REPLICABILIDADE.md ---
# Cache do modelo de embeddings (e5-small). Aponta a um dir estável/vendorável
# para o RAG não re-descarregar da HuggingFace em runtime. Vazio = default.
# MEMVECTOR_MODEL_CACHE=
# Binário do runner agentic (Claude CLI). Default: 'claude' no PATH.
# CLAUDE_BIN=
# Binário do yt-dlp (ingestão YouTube, opcional). Default: ~/.local/bin/yt-dlp.
# Em deploy (IP datacenter) tende a ser bloqueado → proxy/API. Sem ele a
# ingestão YouTube degrada com erro claro; o resto do produto não depende.
# YTDLP_BIN=
